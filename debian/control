Package: roboto-all-x86
Architecture: all
Depends: ${misc:Depends}, roboto-base (>= 1.0.0), roboto-bms (>= 1.0.0), roboto-imu (>= 1.0.0), roboto-motors (>= 1.0.0), roboto-example (>= 1.0.0), roboto-inference (>= 1.0.0)
